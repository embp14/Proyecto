<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyectobd.UsuariosGui.Lst_Usuarios_GuiController">
   <children>
      <Pane prefHeight="39.0" prefWidth="800.0" style="-fx-background-color: #5585b5;">
         <children>
            <Label layoutX="311.0" layoutY="3.0" text="Lista de Usuarios" textFill="WHITE">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
         </children>
      </Pane>
      <TitledPane animated="false" layoutY="39.0" prefHeight="87.0" prefWidth="800.0" text="Filtros">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <Label layoutX="29.0" layoutY="22.0" text="Buscar:" />
                  <TextField fx:id="txt_Buscar" layoutX="75.0" layoutY="18.0" prefHeight="25.0" prefWidth="624.0" />
               </children>
            </AnchorPane>
        </content>
      </TitledPane>
      <TitledPane animated="false" layoutY="126.0" prefHeight="407.0" prefWidth="800.0" text="Registros">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
               <children>
                  <TableView fx:id="tbl_ListaUsuarios" layoutX="14.0" layoutY="14.0" prefHeight="354.0" prefWidth="769.0">
                    <columns>
                      <TableColumn fx:id="col_id" maxWidth="1.7976931348623157E308" prefWidth="75.0" text="ID" />
                      <TableColumn fx:id="col_nombre" maxWidth="1.7976931348623157E308" prefWidth="150.0" text="Nombre" />
                      <TableColumn fx:id="col_email" maxWidth="1.7976931348623157E308" prefWidth="200.0" text="Email" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </AnchorPane>
        </content>
      </TitledPane>
      <TitledPane animated="false" layoutY="533.0" prefHeight="67.0" prefWidth="800.0" text="Acciones">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="27.0" prefWidth="479.0">
               <children>
                  <Button fx:id="btn_Nuevo" layoutX="435.0" layoutY="8.0" mnemonicParsing="false" onAction="#call_NuevoRegistro" text="Nuevo" />
                  <Button fx:id="btn_Editar" layoutX="494.0" layoutY="8.0" mnemonicParsing="false" onAction="#call_Editar" text="Editar" />
                  <Button fx:id="btn_Cerrar" layoutX="552.0" layoutY="8.0" mnemonicParsing="false" onAction="#call_CerrarVentana" text="Cerrar" />
               </children>
            </AnchorPane>
        </content>
      </TitledPane>
   </children>
</AnchorPane>
