   <children>
      <MenuBar>
        <menus>
          <Menu mnemonicParsing="false" text="Administracion">
            <items>
              <MenuItem fx:id="mni_ProbarConexionBD" mnemonicParsing="false" onAction="#call_ProbarConexionBD" text="Probar Conexión BD" />
