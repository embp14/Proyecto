<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane fx:id="Ap_Main" prefHeight="400.0" prefWidth="600.0" stylesheets="@../styles/app.css" styleClass="main-pane" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyectobd.VarianteProductoGui.Mnt_VariantesProducto_GuiController">
    <children>
        <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" spacing="10">
            <children>
                <Pane prefHeight="50.0" prefWidth="600.0" styleClass="header-pane">
                    <children>
                        <Label text="Mantenimiento de Variantes" styleClass="header-label" />
                    </children>
                </Pane>
                <TitledPane text="Detalles" animated="false">
                    <content>
                        <GridPane hgap="10" vgap="10" padding="10">
                            <columnConstraints>
                                <ColumnConstraints minWidth="100" />
                                <ColumnConstraints minWidth="400" />
                            </columnConstraints>
                            <children>
                                <Label text="ID:" GridPane.rowIndex="0" />
                                <TextField fx:id="txt_id" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                <Label text="Producto:" GridPane.rowIndex="1" />
                                <ComboBox fx:id="cmb_producto" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                <Label text="SKU:" GridPane.rowIndex="2" />
                                <TextField fx:id="txt_sku" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                <Label text="Precio:" GridPane.rowIndex="3" />
                                <TextField fx:id="txt_precio" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                <Label text="Stock:" GridPane.rowIndex="4" />
                                <TextField fx:id="txt_stock" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            </children>
                        </GridPane>
                    </content>
                </TitledPane>
                <TitledPane text="Acciones" animated="false">
                    <content>
                        <HBox alignment="CENTER_RIGHT" spacing="10" padding="10">
                            <Button fx:id="btn_Grabar" mnemonicParsing="false" onAction="#call_Grabar" text="Grabar" styleClass="action-button" />
                            <Button fx:id="btn_Cerrar" mnemonicParsing="false" onAction="#call_CerrarVentana" text="Cerrar" styleClass="action-button" />
                        </HBox>
                    </content>
                </TitledPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
